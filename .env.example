# MediSync AI — Environment Configuration
# Copy this file to .env and fill in your actual values

# ─── Node.js Backend ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database (PostgreSQL via Supabase/Neon) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/medisync_db
DATABASE_SSL=true

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=rediss://user:password@your-upstash-host:6379

# ─── AI Service (FastAPI) ─────────────────────────────────────────────────────
AI_SERVICE_URL=http://127.0.0.1:8000

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_char_aes256_key_here_change_me

# ─── Email / SMTP (for OTP / alerts) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── File Upload (Cloudinary or local) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
