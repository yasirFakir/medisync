{
  "name": "@medisync/web-portals",
  "version": "1.0.0",
  "private": true,
  "description": "MediSync AI — Web Portals monorepo (Patient, Doctor, Pharmacy, Admin)",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "preview": "turbo run preview",
    "dev:patient": "turbo run dev --filter=@medisync/portal-patient",
    "dev:doctor": "turbo run dev --filter=@medisync/portal-doctor",
    "dev:pharmacy": "turbo run dev --filter=@medisync/portal-pharmacy",
    "dev:admin": "turbo run dev --filter=@medisync/portal-admin"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
