{
  "name": "medisync-ai",
  "version": "1.0.0",
  "private": true,
  "description": "MediSync AI - AI-Powered Triage Chatbot, Prescription Digitizer, EHR & Pharmacy Portal",
  "scripts": {
    "dev": "pnpm --filter @medisync/web-portals dev",
    "dev:backend": "pnpm --filter @medisync/backend dev",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:init": "psql $DATABASE_URL -f database/init.sql",
    "db:seed": "psql $DATABASE_URL -f database/seed.sql",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
